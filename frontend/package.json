{
	"name": "frontend",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bunx --bun nuxt dev --host",
		"build": "bunx --bun nuxt build",
		"generate": "bunx --bun nuxt generate",
		"preview": "bunx --bun nuxt preview",
		"postinstall": "nuxt prepare",
		"format": "bunx biome format --write .",
		"format:check": "bunx biome format --check .",
		"lint": "bunx biome lint .",
		"lint:fix": "bunx biome lint --write .",
		"check": "bunx biome check . --diagnostic-level=warning"
	},
	"dependencies": {
		"@kyokusu-ui/vue": "^0.0.5",
		"baseline-browser-mapping": "^2.10.33",
		"caniuse-lite": "^1.0.30001793",
		"nuxt": "^4.4.6",
		"vue": "^3.5.34",
		"vue-router": "^5.0.7"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@iconify-json/lucide": "^1.2.109",
		"@iconify-json/ph": "^1.2.2",
		"@nuxt/icon": "^2.2.2",
		"@nuxtjs/color-mode": "^4.0.0",
		"@nuxtjs/tailwindcss": "^6.14.0",
		"@pinia/nuxt": "^0.11.3",
		"@tailwindcss/vite": "^4.3.0",
		"@vueuse/nuxt": "^14.3.0",
		"pinia": "^3.0.4",
		"tailwindcss": "^4.3.0"
	}
