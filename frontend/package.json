{
	"name": "frontend",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bunx --bun nuxt dev --host",
		"build": "bunx --bun nuxt build",
		"generate": "bunx --bun nuxt generate",
		"preview": "bunx --bun nuxt preview",
		"postinstall": "nuxt prepare",
		"lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "fix": "bun run lint:fix && bun run format"
	},
	"dependencies": {
		"@kyokusu-ui/vue": "^0.0.6",
		"baseline-browser-mapping": "^2.10.43",
		"caniuse-lite": "^1.0.30001806",
		"chart.js": "^4.5.1",
		"nuxt": "^4.5.0",
		"vue": "^3.5.40",
		"vue-chartjs": "^5.3.4",
		"vue-router": "^5.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@iconify-json/lucide": "^1.2.118",
		"@iconify-json/ph": "^1.2.2",
		"@nuxt/icon": "^2.3.1",
		"@nuxtjs/color-mode": "^4.0.1",
		"@nuxtjs/tailwindcss": "^6.14.0",
		"@pinia/nuxt": "^1.0.1",
		"@tailwindcss/vite": "^4.3.3",
		"@types/bun": "^1.3.14",
		"@vueuse/nuxt": "^14.3.0",
		"browserslist": "^4.28.6",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.74.0",
		"pinia": "^4.0.2",
		"tailwindcss": "^4.3.3"
	}
}
